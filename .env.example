# EV Tracker — Umgebungsvariablen für docker-compose.yml
#
# Kopieren nach .env und anpassen:
#   cp .env.example .env
#
# PUID/PGID bestimmen unter welchem User der Container läuft.
# Muss mit dem Eigentümer des /data-Volumes übereinstimmen.

# Standard (eigener evtracker-User, UID 10001):
PUID=10001
PGID=100

# Für Unraid (nobody:users = 99:100):
# PUID=99
# PGID=100
