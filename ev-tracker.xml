<?xml version="1.0"?>
<Container version="2">
  <Name>ev-tracker</Name>
  <Repository>19121412/ev-tracker:latest</Repository>
  <Registry>https://hub.docker.com/r/19121412/ev-tracker</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Overview>EV Tracker — Ladeprotokoll für Elektrofahrzeuge. Erfasst Ladevorgänge, Fahrzeugdaten, Live-Zählerstände, Wallbox-Anbindung, Kosten und Exporte. Unterstützt Home Assistant, Tasmota, Shelly, EVCC, OpenWB, go-e, WARP, Alfen, Webasto, Juice und Generic HTTP als Datenquellen. Mehrere Fahrzeuge, automatische Session-Erkennung, Excel-Export, Backup und API.</Overview>
  <Category>Tools: HomeAutomation:</Category>
  <WebUI>http://[IP]:[PORT:8054]/</WebUI>
  <Icon>https://raw.githubusercontent.com/fdreckmann/ev_tracker/main/app/static/favicon.ico</Icon>
  <ExtraParams>--restart unless-stopped</ExtraParams>
  <Support>https://github.com/fdreckmann/ev_tracker/issues</Support>
  <Project>https://github.com/fdreckmann/ev_tracker</Project>
  <Config Name="Web UI Port" Target="8080" Default="8054" Mode="tcp"
    Description="Port für das Web-Dashboard" Type="Port" Display="always" Required="true" Mask="false">8054</Config>
  <Config Name="Daten-Verzeichnis" Target="/data" Default="/mnt/user/appdata/ev-tracker" Mode="rw"
    Description="Speicherort für Config, Datenbank, Exports und Backups" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/ev-tracker</Config>
  <Config Name="DATA_DIR" Target="DATA_DIR" Default="/data"
    Description="Interner Datenpfad" Type="Variable" Display="advanced" Required="true" Mask="false">/data</Config>
  <Config Name="TZ" Target="TZ" Default="Europe/Berlin"
    Description="Zeitzone (z. B. Europe/Berlin, Europe/Zurich, Europe/Vienna)" Type="Variable" Display="always" Required="true" Mask="false">Europe/Berlin</Config>
</Container>
